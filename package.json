{
  "name": "surdoc-api",
  "version": "0.1.0",
  "description": "Unofficial REST API for SURDOC (surdoc.cl), Chile's national museum collections database. Hybrid: live proxy server + static dataset builder.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build:dataset": "bun run scripts/build-dataset.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "bun run scripts/smoke.ts",
    "enrich:aat": "bun run scripts/enrich-aat.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
